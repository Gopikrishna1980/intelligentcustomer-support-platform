# ======================
# APPLICATION
# ======================
APP_NAME=Intelligent Customer Support Platform
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=True

# ======================
# API CONFIGURATION
# ======================
API_V1_PREFIX=/api/v1
SECRET_KEY=your-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ======================
# DATABASE
# ======================
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/support_platform
DB_ECHO=False
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=40

# ======================
# REDIS
# ======================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_URL=redis://localhost:6379/0

# ======================
# OPENAI / AI
# ======================
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-3.5-turbo
OPENAI_MAX_TOKENS=1000
OPENAI_TEMPERATURE=0.7

# ======================
# PINECONE (Vector DB for RAG)
# ======================
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_ENVIRONMENT=us-west1-gcp
PINECONE_INDEX_NAME=support-kb

# ======================
# EMAIL
# ======================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=support@yourcompany.com

# ======================
# WEBSOCKET
# ======================
WS_MESSAGE_QUEUE_SIZE=1000
WS_PING_INTERVAL=30
WS_PING_TIMEOUT=10

# ======================
# RATE LIMITING
# ======================
RATE_LIMIT_ENABLED=True
RATE_LIMIT_PER_MINUTE=100
RATE_LIMIT_PER_HOUR=1000

# ======================
# CORS
# ======================
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
CORS_ALLOW_CREDENTIALS=True

# ======================
# FILE UPLOAD
# ======================
MAX_UPLOAD_SIZE_MB=10
ALLOWED_FILE_TYPES=.jpg,.jpeg,.png,.gif,.pdf,.doc,.docx,.txt

# ======================
# CELERY (Background Tasks)
# ======================
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ======================
# MONITORING
# ======================
SENTRY_DSN=
LOG_LEVEL=INFO

# ======================
# TWILIO (SMS/WhatsApp)
# ======================
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# ======================
# STRIPE (Optional)
# ======================
STRIPE_API_KEY=sk_test_your-stripe-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# ======================
# FRONTEND
# ======================
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
NEXT_PUBLIC_APP_NAME=Customer Support Platform
